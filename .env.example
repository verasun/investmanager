# ===========================================
# InvestManager Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Application
# ===========================================
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# ===========================================
# Database
# ===========================================
# Database backend: sqlite (default) or postgresql
DATABASE_BACKEND=sqlite

# SQLite configuration (used when DATABASE_BACKEND=sqlite)
SQLITE_DB_PATH=./data/investmanager.db

# PostgreSQL configuration (used when DATABASE_BACKEND=postgresql)
DATABASE_URL=postgresql://investuser:investpass@localhost:5432/investmanager
DATABASE_POOL_SIZE=10

# ===========================================
# Local Cache (replaces Redis)
# ===========================================
LOCAL_CACHE_ENABLED=true
LOCAL_CACHE_MAX_SIZE=1000
LOCAL_CACHE_TTL=300

# Redis (optional, for backward compatibility)
REDIS_URL=redis://localhost:6379/0

# ===========================================
# API Keys
# ===========================================
TUSHARE_TOKEN=your_tushare_token_here
ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ===========================================
# Scheduler
# ===========================================
SCHEDULER_ENABLED=true
DAILY_ANALYSIS_TIME=18:00

# ===========================================
# Report
# ===========================================
REPORT_OUTPUT_DIR=./reports

# ===========================================
# Email - SMTP (Legacy, not recommended)
# ===========================================
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your_email@example.com
EMAIL_SMTP_PASSWORD=your_email_password

# ===========================================
# Email - OAuth2 (Recommended)
# ===========================================
# Provider: gmail, outlook, qq, custom
EMAIL_PROVIDER=gmail
EMAIL_OAUTH2_CLIENT_ID=your_client_id
EMAIL_OAUTH2_CLIENT_SECRET=your_client_secret
EMAIL_OAUTH2_REFRESH_TOKEN=your_refresh_token
EMAIL_OAUTH2_TOKEN_URL=
EMAIL_FROM_ADDRESS=your_email@example.com
EMAIL_TO_ADDRESSES=["recipient1@example.com", "recipient2@example.com"]

# ===========================================
# Feishu Integration
# ===========================================
FEISHU_ENABLED=false
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
FEISHU_BITABLE_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_FOLDER_TOKEN=

# ===========================================
# Backtest Settings
# ===========================================
DEFAULT_INITIAL_CAPITAL=1000000.0
DEFAULT_COMMISSION=0.0003