# ===========================================
# InvestManager Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Application
# ===========================================
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# ===========================================
# Working Directory (Multi-Process Architecture)
# ===========================================
# All data, logs, reports stored here
WORK_DIR=/root/autowork

# SQLite database path
SQLITE_DB_PATH=/root/autowork/data/investmanager.db

# Report output directory
REPORT_OUTPUT_DIR=/root/autowork/reports

# ===========================================
# Database
# ===========================================
# Database backend: sqlite (default) or postgresql
DATABASE_BACKEND=sqlite

# PostgreSQL configuration (used when DATABASE_BACKEND=postgresql)
DATABASE_URL=postgresql://investuser:investpass@localhost:5432/investmanager
DATABASE_POOL_SIZE=10

# ===========================================
# Local Cache (replaces Redis)
# ===========================================
LOCAL_CACHE_ENABLED=true
LOCAL_CACHE_MAX_SIZE=1000
LOCAL_CACHE_TTL=300

# Redis (optional, for backward compatibility)
REDIS_URL=redis://localhost:6379/0

# ===========================================
# API Keys
# ===========================================
TUSHARE_TOKEN=your_tushare_token_here
ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# LLM Provider Configuration
# Provider: openai, anthropic, alibaba_bailian
LLM_PROVIDER=alibaba_bailian
# Optional: override default model (provider-specific)
LLM_MODEL=

# Alibaba Bailian (阿里百炼 / DashScope)
# Get your API key from: https://bailian.console.aliyun.com/
ALIBABA_BAILIAN_API_KEY=your_bailian_api_key_here
# Available models: qwen-turbo, qwen-plus, qwen-max, kimi-k2.5, etc.
ALIBABA_BAILIAN_MODEL=kimi-k2.5

# ===========================================
# Scheduler
# ===========================================
SCHEDULER_ENABLED=true
DAILY_ANALYSIS_TIME=18:00

# ===========================================
# Email - SMTP (Legacy, not recommended)
# ===========================================
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your_email@example.com
EMAIL_SMTP_PASSWORD=your_email_password

# ===========================================
# Email - OAuth2 (Recommended)
# ===========================================
# Provider: gmail, outlook, qq, custom
EMAIL_PROVIDER=gmail
EMAIL_OAUTH2_CLIENT_ID=your_client_id
EMAIL_OAUTH2_CLIENT_SECRET=your_client_secret
EMAIL_OAUTH2_REFRESH_TOKEN=your_refresh_token
EMAIL_OAUTH2_TOKEN_URL=
EMAIL_FROM_ADDRESS=your_email@example.com
EMAIL_TO_ADDRESSES='["recipient1@example.com", "recipient2@example.com"]'

# ===========================================
# Feishu Integration
# ===========================================
FEISHU_ENABLED=true
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
FEISHU_BITABLE_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_FOLDER_TOKEN=

# ===========================================
# Backtest Settings
# ===========================================
DEFAULT_INITIAL_CAPITAL=1000000.0
DEFAULT_COMMISSION=0.0003

# ===========================================
# Web Search Settings
# ===========================================
# Enable web search for CHAT mode
WEB_SEARCH_ENABLED=true
# Search engine: duckduckgo (free), tavily, bing
WEB_SEARCH_ENGINE=duckduckgo
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT=10

# Optional: Tavily API (better quality, optimized for AI)
# Get your API key at: https://tavily.com
TAVILY_API_KEY=

# Optional: Bing Search API
# Get your API key at: https://azure.microsoft.com/services/cognitive-services/bing-web-search-api/
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=

# ===========================================
# Claude Code Integration (DEV Mode)
# ===========================================
# Enable Claude Code integration for development mode
CLAUDE_CODE_ENABLED=true
# Working directory for Claude Code
CLAUDE_CODE_WORKING_DIR=/root/autowork

# ===========================================
# Multi-Process Service URLs
# ===========================================
# Used for inter-service communication

# Gateway Service (:8000) - Main entry point
GATEWAY_URL=http://localhost:8000

# LLM Service (:8001) - LLM API proxy
LLM_SERVICE_URL=http://localhost:8001

# Capability Services
INVEST_SERVICE_URL=http://localhost:8010
CHAT_SERVICE_URL=http://localhost:8011
DEV_SERVICE_URL=http://localhost:8012

# Service API Key (optional, for internal service authentication)
SERVICE_API_KEY=